{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://railguard.local/schemas/alert.schema.json",
  "title": "RailGuardAlert",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "source",
    "zoneId",
    "severity",
    "timestamp",
    "riskScore",
    "explanation"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "source": {
      "type": "string",
      "enum": ["cctv", "rtis", "iot", "simulator"]
    },
    "zoneId": {
      "type": "string"
    },
    "severity": {
      "type": "string",
      "enum": ["LOW", "MEDIUM", "HIGH"]
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "riskScore": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "explanation": {
      "type": "object"
    }
  }
}
